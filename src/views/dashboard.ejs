<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Dashboard</h2>
    <p>Welcome, <%= name %>!</p>
    <p>Email: <%= email %></p>

    <% if (user && user.role_name === 'admin') { %>
        <p>
            <a href="/users">View All Users</a>
        </p>
    <% } %>

    <h3>My Volunteer Projects</h3>
    <% if (projects.length > 0) { %>
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                    -
                    <a href="/project/<%= project.project_id %>/remove-volunteer">
                        Remove
                    </a>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>You are not volunteering for any projects.</p>
    <% } %>
</main>

<%- include('partials/footer') %>