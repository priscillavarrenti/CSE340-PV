<%- include('partials/header') %>

<main>

    <h1><%= title %></h1>

    <h2><%= organizationDetails.title %></h2>

    <img
        src="/images/<%= organizationDetails.logo_filename %>"
        alt="<%= organizationDetails.title %> logo"
    >

    <p>
        Description:
        <%= organizationDetails.description %>
    </p>

    <h3>Service Projects</h3>

    <ul>

        <% projects.forEach(project => { %>

            <li>

                <a href="/project/<%= project.project_id %>">

                    <%= project.title %>

                </a>

            </li>

        <% }) %>

    </ul>

</main>

<%- include('partials/footer') %>