<%- include('partials/header') %>

    <main>
        <h1><%= title %></h1>
        <h2>Upcoming Service Projects</h2>

        <p>
            <a href="/new-project">Add New Service Project</a>
        </p>
        
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <h3>
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a>
                    </h3>
                    <p>
                        Organization:
                        <a href="/organization/<%= project.organization_id %>">
                            <%= project.organization_name %>
                        </a>
                    </p>

                    <p><%= project.description %></p>

                    <p>
                        <strong>Location:</strong>
                        <%= project.location %>
                    </p>

                    <p>
                        <strong>Date:</strong>
                        <%= project.date %>
                    </p>

                </li>
            <% }) %>
        </ul>
    </main>

<%- include('partials/footer') %>